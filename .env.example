# Aura AI - Environment Variables
# Copy this file to .env.local and fill in your API keys

# Required for Chat, Summarization, Grammar Check, Code Assistance, Ad Generation
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Required for Image Generation (Primary) and Voice Synthesis
# Get your key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Alternative API key for Gemini (if GEMINI_API_KEY is not set)
# API_KEY=your_api_key_here

# Optional: For Image Generation (Fallback)
# Get your key from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Environment (development/production)
NODE_ENV=development
