{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/*.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/api/tts", "destination": "/api/tts" },
    { "source": "/api/generate-image", "destination": "/api/generate-image" },
    { "source": "/api/proxy-image", "destination": "/api/proxy-image" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
